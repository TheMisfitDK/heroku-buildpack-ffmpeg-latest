#!/usr/bin/env bash
set -e

BUILD_DIR=$1
CACHE_DIR=$2
ENV_DIR=$3

FFMPEG_DIR="$BUILD_DIR/vendor/ffmpeg"
CACHED_TAR="$CACHE_DIR/ffmpeg-latest-linux64-gpl.tar.xz"
DOWNLOAD_URL="https://github.com/BtbN/FFmpeg-Builds/releases/download/latest/ffmpeg-master-latest-linux64-gpl.tar.xz"

mkdir -p "$FFMPEG_DIR" "$CACHE_DIR"

# Use cached tarball if available, otherwise download
if [ -f "$CACHED_TAR" ]; then
  echo "-----> Using cached ffmpeg"
else
  echo "-----> Downloading ffmpeg (BtbN/FFmpeg-Builds)"
  wget -qO "$CACHED_TAR" "$DOWNLOAD_URL"
fi

echo "-----> Installing ffmpeg"
tar -xJ --strip-components=1 -C "$FFMPEG_DIR" -f "$CACHED_TAR"

# Export PATH for subsequent buildpacks and build steps
export PATH="$FFMPEG_DIR/bin:$PATH"
echo "export PATH=\"/app/vendor/ffmpeg/bin:\$PATH\"" > "$BUILD_DIR/.profile.d/ffmpeg.sh"

echo "-----> ffmpeg $(ffmpeg -version 2>&1 | head -1)"
